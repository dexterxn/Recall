<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Recall</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/recall.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a class="logo" asp-page="/Index">recall</a>
        <nav class="site-nav">
            <a asp-page="/Index" class="nav-link">practice</a>
            <a asp-page="/Library" class="nav-link">library</a>
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <script src="~/js/recall.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
